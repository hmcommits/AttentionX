# ================================================================
#  AttentionX — .gitignore
# ================================================================

# Environment / Secrets
.env
*.env.local

# Generated output clips and cached analysis
output/
*.mp4
*.wav
# Python
__pycache__/
*.py[cod]
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Whisper model cache (large binary files)
~/.cache/whisper/
*.pt

# Temporary files
tmp/
temp/
*.tmp
