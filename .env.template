# ================================================================
#  AttentionX — Environment Configuration Template
#  Copy this file to `.env` and fill in your actual values.
#  ⚠️  NEVER commit the real `.env` file to version control.
# ================================================================

# --- Google Gemini ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL_ID=gemini-2.5-flash   # Upgrade to gemini-3-flash when GA

# --- Whisper Transcription ---
# base = ~2 min per hour of video, CPU-friendly for demos
# large-v3-turbo = highest accuracy, requires GPU (cuda) for reasonable speed
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu                  # cpu | cuda

# --- Application Settings ---
APP_ENV=development                 # development | production
APP_LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# --- Output ---
OUTPUT_DIR=./output
MAX_CLIP_DURATION_SEC=60
TARGET_CLIPS_PER_VIDEO=5
